{
  "name": "S2_count_ones",
  "description": "Standalone program: returns 255 if no args; else returns (first byte of argv[1]) + (count of '1' digits in all args) modulo 256.",
  "pretest": {
    "commands": [
      "clang -E -P ./s2.c -o ./s2_pre.c"
    ],
    "input_files": ["s2.c"],
    "output_files": ["s2_pre.c"]
  },
  "test": {
    "commands": [
      "[[result=0]]-v -o ./s2.s ./s2_pre.c"
    ],
    "input_files": ["s2_pre.c"],
    "output_files": ["s2.s"]
  },
  "posttest": {
    "commands": [
      "test -f ./s2.s || (echo '_DEBUG_COMMAND_RESULT=65535' && exit 1)",
      "clang --target=aarch64-apple-darwin -c ./s2.s -o ./s2.o",
      "clang --target=aarch64-apple-darwin ./s2.o -o ./s2",
      "[[debug,result=67]]./s2 A 11"
    ],
    "input_files": ["s2.s"],
    "output_files": ["s2.o", "s2"]
  },
  "regression_files": ["s2.c"],
  "io_files" : ["s2_pre.c", "s2.s"],
  "io_hint": "none",
  "timeout": 5,
  "expected_result": "0"
}
