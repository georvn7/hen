{
  "name": "S0_return_constant",
  "description": "Minimal sanity check: if argc < 2 return 255 (usage error), otherwise always return 3.",
  "pretest": {
    "commands": [
      "clang -E -P ./s0.c -o ./s0_pre.c"
    ],
    "input_files": ["s0.c"],
    "output_files": ["s0_pre.c"]
  },
  "test": {
    "commands": [
      "[[result=0]]-v -o ./s0.s ./s0_pre.c"
    ],
    "input_files": ["s0_pre.c"],
    "output_files": ["s0.s"]
  },
  "posttest": {
    "commands": [
      "test -f ./s0.s || (echo '_DEBUG_COMMAND_RESULT=65535' && exit 1)",
      "clang --target=aarch64-apple-darwin -c ./s0.s -o ./s0.o",
      "clang --target=aarch64-apple-darwin ./s0.o -o ./s0",
      "[[debug,result=255]]./s0"
    ],
    "input_files": ["s0.s"],
    "output_files": ["s0.o", "s0"]
  },
  "io_hint": "Handle the missing-argument case using the designated early-return value, and otherwise return the fixed success value exactly as specified."
}
